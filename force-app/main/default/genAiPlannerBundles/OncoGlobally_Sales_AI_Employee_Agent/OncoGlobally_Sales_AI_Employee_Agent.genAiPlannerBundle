            <language>en_US</language>
            <masterLabel>instructions_0_1777270175764</masterLabel>
            <sortOrder>5</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Based on output, show if error/ successfully created records, need not show the expense record id in the output</description>
